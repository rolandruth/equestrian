# ============================================================
# Directory Master — Environment Variables Reference
# ============================================================
# Copy this file to .env for local development.
# On Replit, set these as Secrets (Tools → Secrets).
# Never commit real secrets to version control.
# ============================================================

# ----------------------------------------------------------
# DATABASE (Required)
# ----------------------------------------------------------
# Automatically provisioned and set by Replit when you add
# the PostgreSQL database via Tools → Database.
# For local development, supply your own PostgreSQL URL.
DATABASE_URL=postgresql://user:password@localhost:5432/directory_master

# ----------------------------------------------------------
# SESSION SECURITY (Required)
# ----------------------------------------------------------
# A strong random string used to sign session tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 32 characters. Keep this secret.
SESSION_SECRET=replace-this-with-a-long-random-string-at-least-64-chars

# ----------------------------------------------------------
# GEMINI AI (Optional — enables CSV import enrichment)
# ----------------------------------------------------------
# Used to auto-generate entry summaries and tags during CSV import.
# Get a free key at: https://aistudio.google.com/app/apikey
# If omitted, CSV import still works but without AI enrichment.
GEMINI_API_KEY=

# ----------------------------------------------------------
# OBJECT STORAGE (Optional — auto-provisioned by Replit)
# ----------------------------------------------------------
# Set automatically by Replit when App Storage is enabled.
# Leave blank for local development unless you configure
# your own S3-compatible storage.
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=private
PUBLIC_OBJECT_SEARCH_PATHS=public
